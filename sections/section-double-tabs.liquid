<!-- /sections/section-double-tabs.liquid -->

{% liquid
  assign animation_anchor = "[data-section-id='" | append: section.id | append: "']"

  assign border_class = ''
  if section.settings.borders
    assign border_class = 'brick--border'
  endif

  assign margin_class = ''
  if section.settings.brick_gutter > 0
    assign margin_class = 'brick--margin'
  endif

  if section.settings.preload_image
    assign preload = true
    assign loading = 'eager'
    assign fetchpriority = 'high'
  else
    assign preload = false
    assign loading = 'lazy'
  endif
%}

{%- capture image_block_sizes -%}
  {%- render 'image-grid-sizes',
    columns_desktop: 2,
    columns_tablet: 2,
    columns_mobile: 1.0,
    section_width: section.settings.width
  %}
{%- endcapture -%}

{%- comment -%} Collect only tab blocks {%- endcomment -%}
{%- assign first_tab = 0 -%}
{%- assign tab_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'tab' -%}
    {%- assign tab_count = tab_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

<section
  data-section-id="{{ section.id }}"
  data-section-type="double-tabs"
  style="
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;
    --BRICK-GUTTER: {{ section.settings.brick_gutter }}px;
    {% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }};{% endif %}
  "
>
  <div class="section-padding {{ section.settings.width }}" data-wrapper>
    <div
      class="brick__section brick--2 {{ margin_class }} {{ border_class }} {{ section.settings.height }}"
      data-overflow-wrapper
    >

      {%- comment -%} ── LEFT: Tabs panel ── {%- endcomment -%}
      <div
        class="brick__block"
        data-prevent-transparent-header
        x-data="doubleTabs({{ first_tab }})"
      >
        {%- assign bg_color = section.settings.tabs_bg_color -%}
        {%- assign transparent_spacing_class = '' -%}
        {%- if bg_color == 'rgba(0,0,0,0)' or bg_color == blank -%}
          {%- assign transparent_spacing_class = 'brick__block__text--transparent' -%}
        {%- endif -%}

        <div
          class="brick__block__text {{ transparent_spacing_class }} {{ section.settings.text_color }}"
          data-overflow-frame
          style="--bg: {{ bg_color }};"
        >
          <div class="brick__block__text__inner">
            <div class="text__standard {{ section.settings.align_text }}" data-overflow-content>

              {%- if section.settings.heading != blank -%}
                <h2
                  class="standard__heading heading-size-9"
                  data-aos="hero"
                  data-aos-anchor="{{ animation_anchor }}"
                  data-aos-order="1"
                >
                  {{ section.settings.heading }}
                </h2>
              {%- endif -%}

              {%- comment -%} Tab name grid {%- endcomment -%}
              {%- if tab_count > 0 -%}
                <div
                  class="brick-tabs__nav"
                  role="tablist"
                  data-aos="hero"
                  data-aos-anchor="{{ animation_anchor }}"
                  data-aos-order="2"
                >
                  {%- assign tab_nav_index = 0 -%}
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'tab' -%}
                      <button
                        type="button"
                        class="brick-tabs__nav-item type-body"
                        :class="activeTab === {{ tab_nav_index }} ? 'brick-tabs__nav-item--active' : ''"
                        @click="activeTab = {{ tab_nav_index }}"
                        role="tab"
                        :aria-selected="activeTab === {{ tab_nav_index }}"
                        {{ block.shopify_attributes }}
                        {%- if request.design_mode -%}
                          @shopify:block:select="activeTab = {{ tab_nav_index }}"
                        {%- endif -%}
                      >
                        {{ block.settings.title }}
                      </button>
                      {%- assign tab_nav_index = tab_nav_index | plus: 1 -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                {%- comment -%} Tab content panels {%- endcomment -%}
                <div
                  class="brick-tabs__panels"
                  data-aos="hero"
                  data-aos-anchor="{{ animation_anchor }}"
                  data-aos-order="3"
                >
                  {%- assign tab_panel_index = 0 -%}
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'tab' -%}
                      <div
                        class="brick-tabs__panel rte"
                        role="tabpanel"
                        x-show="activeTab === {{ tab_panel_index }}"
                        x-transition:enter="brick-tabs__panel--enter"
                        x-transition:enter-start="brick-tabs__panel--enter-start"
                        x-transition:enter-end="brick-tabs__panel--enter-end"
                        {% unless tab_panel_index == 0 %}x-cloak{% endunless %}
                      >
                        {%- if block.settings.title != blank -%}
                          <h3 class="brick-tabs__panel-title">{{ block.settings.title }}</h3>
                        {%- endif -%}
                        {%- if block.settings.kicker != blank -%}
                          <p class="brick-tabs__panel-kicker standard__kicker">{{ block.settings.kicker }}</p>
                        {%- endif -%}
                        {%- if block.settings.content != blank -%}
                          <div class="brick-tabs__panel-content body-size-{{ section.settings.font_size }}">
                            {{ block.settings.content }}
                          </div>
                        {%- endif -%}
                      </div>
                      {%- assign tab_panel_index = tab_panel_index | plus: 1 -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}

            </div>
          </div>
        </div>
      </div>

      {%- comment -%} ── RIGHT: Image panel ── {%- endcomment -%}
      <div class="brick__block" data-overflow-frame>
        <div class="brick__block__image">
          <div class="image-overlay" style="--bg:{{ section.settings.overlay_color }}; opacity:{{ section.settings.overlay_opacity | times: 0.01 }};"></div>
          {%- capture srcset -%}
            {%- render 'image-grid-srcset',
              image: section.settings.image,
              columns_desktop: 2,
              columns_tablet: 2,
              columns_mobile: 1.0,
              section_width: section.settings.width
            %}
          {%- endcapture -%}
          {%- render 'image-parallax',
            img_object: section.settings.image,
            frame_height_class: section.settings.height,
            srcset: srcset,
            sizes: image_block_sizes,
            preload: preload,
            loading: loading,
            fetchpriority: fetchpriority
          -%}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Brick Tabs (double-tabs section) ── */
  .brick-tabs__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25em 1.5em;
    margin-bottom: 2.5rem;
    margin-top: 1.5rem;
  }

  .brick-tabs__nav-item {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: currentColor;
    opacity: 0.45;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.7rem;
    transition: opacity 0.2s ease;
    text-align: left;
  }

  .brick-tabs__nav-item:hover {
    opacity: 0.75;
  }

  .brick-tabs__nav-item--active {
    opacity: 1 !important;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .brick-tabs__panels {
    position: relative;
  }

  .brick-tabs__panel {
    animation: brickTabFadeIn 0.35s ease forwards;
  }

  .brick-tabs__panel-title {
    font-size: 1.35rem;
    font-weight: 400;
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
  }

  .brick-tabs__panel-kicker {
    margin: 0 0 1rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .brick-tabs__panel-content {
    line-height: 1.65;
  }

  @keyframes brickTabFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  [x-cloak] { display: none !important; }
</style>

<script>
  function doubleTabs(initial) {
    return {
      activeTab: initial || 0
    }
  }
</script>

{% schema %}
{
  "name": "Image with tabs",
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name / Tab label",
          "default": "Tab label",
          "info": "Displayed in the tab navigation list"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker / Role",
          "info": "Small uppercase label shown below the name in the panel, e.g. 'CEO TASHAS GROUP'"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add your rich text content here. You can use <strong>bold</strong>, <em>italics</em>, links, and more.</p>"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The standard amongst industry leaders"
    },
    {
      "type": "select",
      "id": "align_text",
      "label": "Text alignment",
      "default": "text-left",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Centered" },
        { "value": "text-right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Content text size",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "info": "Increase contrast for legible text.",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "default": "text--neutral",
      "options": [
        { "value": "text--neutral", "label": "Normal text" },
        { "value": "text--white", "label": "White" },
        { "value": "text--primary", "label": "Primary accent" },
        { "value": "text--secondary", "label": "Secondary accent" },
        { "value": "text--black", "label": "Black" },
        { "value": "text--invert--primary", "label": "Primary dark accent" },
        { "value": "text--invert--secondary", "label": "Secondary dark accent" },
        { "value": "text--invert", "label": "Inverted text color" },
        { "value": "text--bright--primary", "label": "Primary bright accent" },
        { "value": "text--bright--secondary", "label": "Secondary bright accent" }
      ]
    },
    {
      "type": "color",
      "id": "tabs_bg_color",
      "label": "Text panel background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background"
    },
    {
      "type": "header",
      "content": "Section height"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "default": "use_screen_one_half",
      "options": [
        { "value": "use_screen_full", "label": "Full screen height" },
        { "value": "use_screen_three_quarters", "label": "Three quarters of screen height" },
        { "value": "use_screen_two_thirds", "label": "Two thirds of screen height" },
        { "value": "use_screen_one_half", "label": "One half of screen height" },
        { "value": "use_screen_one_third", "label": "One third of screen height" },
        { "value": "use_screen_one_fifth", "label": "One fifth of screen height" },
        { "value": "use_pixels_800", "label": "800px" },
        { "value": "use_pixels_650", "label": "650px" },
        { "value": "use_pixels_500", "label": "500px" },
        { "value": "use_image", "label": "Image height" }
      ]
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--none", "label": "Full width" },
        { "value": "wrapper--full", "label": "Full width padded" },
        { "value": "wrapper", "label": "Page width" },
        { "value": "wrapper--narrow", "label": "Page width narrow" },
        { "value": "wrapper--tiny", "label": "Page width extra narrow" }
      ]
    },
    {
      "type": "range",
      "id": "brick_gutter",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Gap between panels",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "borders",
      "label": "Add borders",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "preload_image",
      "label": "Prioritize image load",
      "default": false,
      "info": "Enable when this section appears at the top of the page."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Image with tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "title": "Natasha Sideris",
            "kicker": "CEO Tashas Group",
            "content": "<p>Add a quote or description for this person here.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "title": "Ryan Cole",
            "kicker": "Creative Director",
            "content": "<p>Add a quote or description for this person here.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "title": "Braam Beyers",
            "kicker": "Head of Operations",
            "content": "<p>Add a quote or description for this person here.</p>"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}


<style>
@media (min-width: 768px){
.brick-tabs__panels {
  display: grid;
  grid-template-columns: 1fr;
  align-items: start;
}

.brick-tabs__panel {
  grid-area: 1 / 1; 
}

.brick-tabs__panel[style*="display: none"] {
  display: block !important; 
  visibility: hidden;
  pointer-events: none;
  user-select: none;
}

.brick-tabs__panel:not([style*="display: none"]) {
  visibility: visible;
  pointer-events: auto;
  position: relative;
  z-index: 1;
}
}
</style>